import java.io.File;
import java.io.PrintWriter;
import java.util.ArrayList;
import java.util.Scanner;

public class MediaTracker {

    public static void main(String[] args) throws Exception {

        // Scanner for user input
        Scanner scanner = new Scanner(System.in);

        // ArrayLists to store media information
        ArrayList<String> titles = new ArrayList<>();
        ArrayList<String> types = new ArrayList<>();
        ArrayList<Integer> ratings = new ArrayList<>();
        ArrayList<String> statuses = new ArrayList<>();


        // Opens the save file
        File file = new File("media.txt");

        // Loads saved data if the file already exists
        if (file.exists()) {

            Scanner fileScanner = new Scanner(file);

            // Reads each media item from the file
            while (fileScanner.hasNextLine()) {

                titles.add(fileScanner.nextLine());
                types.add(fileScanner.nextLine());
                ratings.add(Integer.parseInt(fileScanner.nextLine()));
                statuses.add(fileScanner.nextLine());
            }

            fileScanner.close();
        }


        // Keeps the program running until the user exits
        boolean running = true;

        while (running) {

            // Menu options
            System.out.println("\n1. Add Media");
            System.out.println("2. View All");
            System.out.println("3. Sort By Rating");
            System.out.println("4. Exit");

            System.out.print("Choose: ");
            int choice = scanner.nextInt();
            scanner.nextLine();

            // Adds a new media item
            if (choice == 1) {

                System.out.print("Title: ");
                String title = scanner.nextLine();

                System.out.print("Type: ");
                String type = scanner.nextLine();

                System.out.print("Rating(1-10): ");
                int rating = scanner.nextInt();
                scanner.nextLine();

                System.out.print("Status: ");
                String status = scanner.nextLine();

                // Adds data to the ArrayLists
                titles.add(title);
                types.add(type);
                ratings.add(rating);
                statuses.add(status);

                System.out.println("Added!");


            // Displays all media items
            } else if (choice == 2) {

                for (int i = 0; i < titles.size(); i++) {

                    System.out.println("\nTitle: " + titles.get(i));
                    System.out.println("Type: " + types.get(i));
                    System.out.println("Rating: " + ratings.get(i));
                    System.out.println("Status: " + statuses.get(i));
                }


            // Sorts media by highest rating
            } else if (choice == 3) {

                // Bubble sort
                for (int i = 0; i < ratings.size() - 1; i++) {

                    for (int j = 0; j < ratings.size() - i - 1; j++) {

                        // Swaps items if the current rating is lower
                        if (ratings.get(j) < ratings.get(j + 1)) {

                            int tempRating = ratings.get(j);
                            ratings.set(j, ratings.get(j + 1));
                            ratings.set(j + 1, tempRating);

                            String tempTitle = titles.get(j);
                            titles.set(j, titles.get(j + 1));
                            titles.set(j + 1, tempTitle);

                            String tempType = types.get(j);
                            types.set(j, types.get(j + 1));
                            types.set(j + 1, tempType);

                            String tempStatus = statuses.get(j);
                            statuses.set(j, statuses.get(j + 1));
                            statuses.set(j + 1, tempStatus);
                        }
                    }
                }

                System.out.println("Sorted!");


            // Saves data and exits the program
            } else if (choice == 4) {

                PrintWriter writer = new PrintWriter("media.txt");

                // Writes all media data into the file
                for (int i = 0; i < titles.size(); i++) {

                    writer.println(titles.get(i));
                    writer.println(types.get(i));
                    writer.println(ratings.get(i));
                    writer.println(statuses.get(i));
                }

                writer.close();

                System.out.println("Saved!");

                running = false;
            }
        }

        // Closes scanner
        scanner.close();
    }
}
